DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=*
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DUCKDB_PATH=data/datalake.duckdb

# 数据底座 PostgreSQL(业务数据建模主库;连不上时自动降级 DuckDB)
POSTGRES_HOST=127.0.0.1
POSTGRES_HOST_FALLBACK=
POSTGRES_PORT=5432
POSTGRES_DB=liangce
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_SCHEMA=lake

# LightRAG / Apache AGE 图谱(按 source_id 过滤导入)
LIGHTRAG_SOURCE_ID=
# 留空则按 graph_sources.workspace 自动解析;也可手动指定
LIGHTRAG_WORKSPACE=

# 对话 Chat(OpenAI 兼容 /v1/chat/completions)。不填则意图识别/圆桌降级为规则或 Mock
# 可用型号以网关 GET /v1/models 为准（前端会自动拉取）
LLM_API_KEY=
LLM_BASE_URL=https://ai.centos.hk/v1
LLM_MODEL=gpt-5.4-mini
LLM_MODEL_FAST=gpt-5.4-mini

# 图片专用密钥 — 仅文生图 /images/generations、图生图 /images/edits（不要用来调 Chat）
IMAGE_API_KEY=
IMAGE_BASE_URL=https://ai.centos.hk/v1
IMAGE_GEN_MODEL=gpt-image-2
IMAGE_EDIT_MODEL=gpt-image-2
# 识图走模型密钥 + Chat；填对话 Key 下的型号
IMAGE_VISION_MODEL=gpt-5.4

# 吉客云只读同步(不填则用内置样例数据灌入 DataLake,src=jackyun)
JACKYUN_APP_KEY=
JACKYUN_APP_SECRET=
JACKYUN_BASE_URL=https://open.jackyun.com/open/openapi/do
JACKYUN_METHOD_GOODS=erp.goods.listget
JACKYUN_METHOD_TRADE=oms.trade.listget

# MCP 业务系统接入(HTTP/SSE 填 URL;stdio 填 COMMAND + ARGS)
# 企业微信: 填企微后台 StreamableHttp URL
MCP_WECOM_URL=
MCP_TENCENT_DOCS_URL=
MCP_WEDRIVE_URL=
MCP_KINGDEE_URL=
MCP_JACKYUN_URL=
MCP_WORKBUDDY_URL=
MCP_NAS_COMMAND=npx
MCP_NAS_ARGS=["-y","@modelcontextprotocol/server-filesystem","/path/to/nas"]

# 腾讯云 COS — 通用媒体与 Skill 仓库分离
USE_TENCENT_COS=false
TENCENT_COS_SECRET_ID=
TENCENT_COS_SECRET_KEY=
TENCENT_COS_BUCKET=
TENCENT_COS_REGION=ap-guangzhou
TENCENT_COS_CUSTOM_DOMAIN=
TENCENT_COS_SCHEME=https
TENCENT_COS_LOCATION=media
TENCENT_COS_ACL=public-read
# Skill 专用桶(建议新建,与 media 桶分离);留空则复用 TENCENT_COS_BUCKET + skills/ 路径
TENCENT_COS_SKILLS_BUCKET=
TENCENT_COS_SKILLS_LOCATION=skills
