# 良策本地 Agent 配置
# 复制为 %LOCALAPPDATA%\liangce-agent\config.env (Windows)
# 或 ~/.local/share/liangce-agent/config.env (Linux/macOS)

LIANGCE_HOST=127.0.0.1
LIANGCE_PORT=5050
LIANGCE_SECRET_KEY=请改成随机字符串

# 微信开放平台 · 网站应用（扫码登录）
# https://open.weixin.qq.com/
WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_REDIRECT_URI=http://127.0.0.1:5050/auth/wechat/callback

# 未配置微信时允许本地开发登录
ALLOW_DEV_LOGIN=true

# LLM（可选，也可登录后在界面设置）
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat
